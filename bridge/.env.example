# Base RPC endpoints
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org

# Deployer/bridge operator private key (NEVER commit this file!)
DEPLOYER_PRIVATE_KEY=

# BaseScan API key for contract verification
BASESCAN_API_KEY=

# Deployed contract addresses (set after deployment)
WDIL_CONTRACT=
WDILV_CONTRACT=

# Bridge deposit addresses on native chains
DIL_BRIDGE_ADDRESS=
DILV_BRIDGE_ADDRESS=

# Dilithion RPC
DIL_RPC_URL=http://127.0.0.1:8332
DILV_RPC_URL=http://127.0.0.1:9332
RPC_USER=rpc
RPC_PASSWORD=rpc
